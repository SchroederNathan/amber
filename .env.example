# Copy to .env.local and fill in. Client vars (EXPO_PUBLIC_*) are bundled into the app.
# Do NOT put backend secrets here — set those on the Convex deployment (see below).

# --- Client (Expo) ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://<your-deployment>.convex.site

# --- Convex deployment env (set with `bunx convex env set <NAME> <value>`, NOT via this file) ---
# AI_GATEWAY_API_KEY=<your-vercel-ai-gateway-key>
# CLERK_JWT_ISSUER_DOMAIN=https://<your-clerk-instance>.clerk.accounts.dev
